@page "/standard/{id:int}"
@rendermode InteractiveServer
@inject StandardDbContext Db
@inject StandardArchiveService ArchiveService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>标准详情</PageTitle>

<div class="container">
    @if (record == null)
    {
        <p>加载中...</p>
    }
    else
    {
        <div class="detail-header">
            <h1>@record.StandardNumber</h1>
            <span class="status-badge status-@record.Status.ToString().ToLowerInvariant()">@record.StatusDisplay</span>
        </div>

        <div class="detail-grid">
            <div class="detail-item">
                <span class="detail-label">版本</span>
                <span class="detail-value">@(string.IsNullOrWhiteSpace(record.Version) ? "-" : record.Version)</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">上传时间</span>
                <span class="detail-value">@record.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">所属领域</span>
                <span class="detail-value">@(record.Domain?.Name ?? "未分类")</span>
            </div>
        </div>

        <div class="detail-item full-width">
            <span class="detail-label">Markdown 文件</span>
            <code class="detail-value">@Path.Combine(record.StoragePath, record.MarkdownFileName)</code>
        </div>

        <div class="detail-actions">
            <a class="btn btn-primary" href="/standard/@record.Id/view">查看正文</a>
            <button class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                @(isDeleting ? "删除中..." : "删除此标准")
            </button>
            <a class="btn" href="/">返回列表</a>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @(isError ? "alert-danger" : "alert-success")">
                @message
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private StandardRecord? record;
    private string? message;
    private bool isError;
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        record = await Db.Standards.AsNoTracking().Include(s => s.Domain).FirstOrDefaultAsync(s => s.Id == Id);
        if (record == null)
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task ConfirmDelete()
    {
        if (record == null)
            return;

        if (!await JS.InvokeAsync<bool>("confirm", $"确定要删除标准 {record.StandardNumber} 吗？此操作会同时删除归档文件。"))
            return;

        isDeleting = true;
        try
        {
            await ArchiveService.DeleteAsync(record.Id);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            message = $"删除失败：{ex.Message}";
            isError = true;
        }
        finally
        {
            isDeleting = false;
        }
    }
}
