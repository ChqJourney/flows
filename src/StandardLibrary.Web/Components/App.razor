<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["StandardLibrary.Web.styles.css"]" />
    <link rel="stylesheet" href="lib/katex/katex.min.css" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="lib/katex/katex.min.js"></script>
    <script src="lib/katex/contrib/auto-render.min.js"></script>
    <script>
        window.renderStandardMath = function (elementId) {
            var element = document.getElementById(elementId);
            if (!element || typeof renderMathInElement === 'undefined') return;
            renderMathInElement(element, {
                delimiters: [
                    { left: '$$', right: '$$', display: true },
                    { left: '$', right: '$', display: false }
                ],
                throwOnError: false
            });
        };
    </script>
</body>

</html>
